# =============================================================================
# evuno — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Docker service credentials (used by docker-compose.yml)
# Change these before any shared/production deployment
# -----------------------------------------------------------------------------
POSTGRES_USER=evuno
POSTGRES_PASSWORD=evuno_dev
RABBITMQ_USER=evuno
RABBITMQ_PASSWORD=evuno_dev
MINIO_ROOT_USER=evuno
MINIO_ROOT_PASSWORD=evuno_dev_minio
VALKEY_PASSWORD=evuno_dev
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# -----------------------------------------------------------------------------
# Database (PostgreSQL + TimescaleDB)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://evuno:evuno_dev@localhost:5432/evuno

# -----------------------------------------------------------------------------
# Auth (Keycloak)
# -----------------------------------------------------------------------------
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=evuno
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# CitrineOS (OCPP)
# -----------------------------------------------------------------------------
CITRINEOS_API_URL=http://localhost:8081
CITRINEOS_DB_URL=postgresql://evuno:evuno_dev@localhost:5432/evuno_citrine

# -----------------------------------------------------------------------------
# Payments (Stripe — AU + CL)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Maps (Mapbox)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_SECRET_TOKEN=

# -----------------------------------------------------------------------------
# EV Routing (Chargetrip)
# -----------------------------------------------------------------------------
CHARGETRIP_CLIENT_ID=
CHARGETRIP_APP_ID=

# -----------------------------------------------------------------------------
# Charger Data (Open Charge Map + NREL)
# -----------------------------------------------------------------------------
OPEN_CHARGE_MAP_API_KEY=
NREL_API_KEY=

# -----------------------------------------------------------------------------
# Scout ROI Tool (Google Places)
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# MinIO (local S3-compatible storage for CitrineOS)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://evuno:evuno_dev@localhost:5672

# -----------------------------------------------------------------------------
# Valkey (Redis-compatible cache)
# -----------------------------------------------------------------------------
VALKEY_URL=redis://:evuno_dev@localhost:6379

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SCOUT_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
NODE_ENV=development
