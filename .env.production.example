# =============================================================================
# evuno — Production Environment Variables
# Copy to .env.local on the Hetzner server and fill in real values
# =============================================================================

# --- Docker Services --------------------------------------------------------
POSTGRES_USER=evuno
POSTGRES_PASSWORD=<GENERATE_STRONG_PASSWORD>
RABBITMQ_USER=evuno
RABBITMQ_PASSWORD=<GENERATE_STRONG_PASSWORD>
MINIO_ROOT_USER=evuno
MINIO_ROOT_PASSWORD=<GENERATE_STRONG_PASSWORD>
VALKEY_PASSWORD=<GENERATE_STRONG_PASSWORD>
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<GENERATE_STRONG_PASSWORD>

# --- Database ---------------------------------------------------------------
DATABASE_URL=postgresql://evuno:<DB_PASSWORD>@localhost:5432/evuno

# --- Auth (Keycloak) -------------------------------------------------------
KEYCLOAK_URL=https://auth.evuno.co
KEYCLOAK_REALM=evuno
KEYCLOAK_CLIENT_ID=evuno-charge
# No client secret needed — public client with PKCE

# --- CitrineOS (OCPP) ------------------------------------------------------
CITRINEOS_API_URL=http://localhost:8081
CITRINEOS_DB_URL=postgresql://evuno:<DB_PASSWORD>@localhost:5432/evuno_citrine

# --- Payments (Stripe) -----------------------------------------------------
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Maps (Mapbox) ----------------------------------------------------------
# Get from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
MAPBOX_SECRET_TOKEN=sk.eyJ1...

# --- EV Routing (Chargetrip) -----------------------------------------------
# Get from https://account.chargetrip.com/
CHARGETRIP_CLIENT_ID=
CHARGETRIP_APP_ID=

# --- Charger Data -----------------------------------------------------------
OPEN_CHARGE_MAP_API_KEY=
NREL_API_KEY=

# --- Scout (Google Places) --------------------------------------------------
GOOGLE_PLACES_API_KEY=

# --- Email (Resend) ---------------------------------------------------------
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- Infrastructure ---------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
RABBITMQ_URL=amqp://evuno:<RABBITMQ_PASSWORD>@localhost:5672
VALKEY_URL=redis://:<VALKEY_PASSWORD>@localhost:6379

# --- App URLs ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://charge.evuno.co
NEXT_PUBLIC_API_URL=https://api.evuno.co/api
NODE_ENV=production
