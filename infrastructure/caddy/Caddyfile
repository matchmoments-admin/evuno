# =============================================================================
# evuno — Caddy reverse proxy config
# Handles: auto HTTPS (Let's Encrypt), HTTP->HTTPS, WebSocket, gzip
# =============================================================================

# Local development (use localhost domains)
# In production, replace with actual domains: charge.evuno.co, etc.

:3080 {
	reverse_proxy localhost:3000
	header {
		X-Evuno-App "charge"
	}
}

:3081 {
	reverse_proxy localhost:3001
	header {
		X-Evuno-App "navigate"
	}
}

:3082 {
	reverse_proxy localhost:3002
	header {
		X-Evuno-App "scout"
	}
}

:4080 {
	reverse_proxy localhost:4000
	header {
		X-Evuno-App "api"
	}
}

