{
  "realm": "evuno",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "internationalizationEnabled": true,
  "supportedLocales": ["en", "es"],
  "defaultLocale": "es",
  "roles": {
    "realm": [
      {
        "name": "operator",
        "description": "Charging station operator"
      },
      {
        "name": "driver",
        "description": "EV driver"
      },
      {
        "name": "admin",
        "description": "Platform administrator"
      }
    ]
  },
  "groups": [
    {
      "name": "tenant:demo-au",
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000001"]
      }
    },
    {
      "name": "tenant:demo-cl",
      "attributes": {
        "tenant_id": ["00000000-0000-0000-0000-000000000002"]
      }
    }
  ],
  "clients": [
    {
      "clientId": "evuno-charge",
      "name": "evuno Charge",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/auth/callback"],
      "webOrigins": ["http://localhost:3000"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email"],
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "tenant_id",
            "full.path": false,
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "evuno-navigate",
      "name": "evuno Navigate",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3001/auth/callback"],
      "webOrigins": ["http://localhost:3001"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email"]
    },
    {
      "clientId": "evuno-scout",
      "name": "evuno Scout",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3002/auth/callback"],
      "webOrigins": ["http://localhost:3002"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email"]
    },
    {
      "clientId": "evuno-api",
      "name": "evuno API",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["openid", "profile", "email"]
    },
    {
      "clientId": "evuno-mobile",
      "name": "evuno Mobile",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["evuno://auth/callback"],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["openid", "profile", "email"]
    }
  ]
}
